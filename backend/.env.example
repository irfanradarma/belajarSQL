NODE_ENV=development
PORT=4000

# Per-connection tuning defaults — students supply the actual server,
# database, username, and password themselves via the app's Connect page
# (POST /api/connect), so there's no fixed DB connection to configure here.
DB_REQUEST_TIMEOUT_MS=120000
DB_CONNECTION_TIMEOUT_MS=15000
MAX_ROWS_DEFAULT=5000
MAX_ROWS_HARD_CAP=20000

SESSION_IDLE_TIMEOUT_MS=600000

CORS_ALLOWED_ORIGINS=http://localhost:5173
